#!/bin/bash
# Phase 3 (2026-04-27): outbox watcher for brain → Claude-targeted task envelopes.
# 2026-05-14: execution backend switched from Claude prompt-mode CLI to Codex
# gpt-5.5. The script name/outbox path remain for backward compatibility with
# existing launchd WatchPaths and /brain/command target semantics.
#
# Triggered by launchd WatchPaths on ~/.brain_outbox/claude/pending/. Each
# pending JSON file represents a brain-issued task. Behavior:
#
# 1. If BRAIN_AUTOSPAWN_CLAUDE != on, leave the file alone (audit-only).
# 2. Otherwise, read the envelope, invoke Codex gpt-5.5 headlessly, capture
#    stdout, ack the brain message, move file to done/ on success or failed/
#    on error.
#
# Default OFF: spawning agent sessions is high-cost (LLM tokens) and high
# blast-radius (writes files / commits / etc.). Chris must opt in:
#
#   echo "BRAIN_AUTOSPAWN_CLAUDE=on" >> ~/.openclaw/credentials/.env
#   launchctl setenv BRAIN_AUTOSPAWN_CLAUDE on
#
# Until then this script is a no-op safety harness.

set -uo pipefail

OUTBOX="$HOME/.brain_outbox/claude"
PENDING="$OUTBOX/pending"
DONE="$OUTBOX/done"
FAILED="$OUTBOX/failed"
LOG_DIR="/Users/chrischo/server/brain/logs/jobs"
LOG_FILE="$LOG_DIR/brain_spawn_claude.log"
SECRET_FILE="$HOME/.openclaw/credentials/.personal_webhook_secret"
BRAIN_URL="${BRAIN_URL:-http://127.0.0.1:8791}"
CODEX_BIN="${BRAIN_CODEX_BIN:-${CODEX_BIN:-/opt/homebrew/bin/codex}}"
CODEX_MODEL="${BRAIN_CODEX_PRIMARY_MODEL:-gpt-5.5}"

mkdir -p "$PENDING" "$DONE" "$FAILED" "$LOG_DIR"

log() {
  printf '%s %s\n' "$(date +%Y-%m-%dT%H:%M:%SZ)" "$1" >> "$LOG_FILE"
}

run_codex() {
  local task="$1"
  local output_file="$2"
  printf '%s' "$task" | timeout 600 "$CODEX_BIN" exec --skip-git-repo-check -m "$CODEX_MODEL" - \
    > "$output_file" 2>&1
}

# Guard: spawn disabled by default
ENABLED="${BRAIN_AUTOSPAWN_CLAUDE:-off}"
if [ "$ENABLED" != "on" ]; then
  log "spawn disabled (BRAIN_AUTOSPAWN_CLAUDE=$ENABLED) — leaving outbox untouched"
  exit 0
fi

[ -x "$CODEX_BIN" ] || { log "codex bin missing at $CODEX_BIN"; exit 0; }
command -v jq >/dev/null 2>&1 || { log "jq missing"; exit 0; }
[ -r "$SECRET_FILE" ] || { log "secret file missing"; exit 0; }

# Bound concurrency to 1 spawn at a time so we don't fork-bomb on a burst.
LOCK_FILE="/tmp/.brain_spawn_claude.lock"
exec 9>"$LOCK_FILE"
if ! flock -n 9; then
  log "another spawn in flight — skipping this trigger"
  exit 0
fi

# Process at most 3 pending envelopes per trigger so a backlog doesn't
# wedge the watcher in a single very long batch.
MAX_PER_RUN=3
processed=0

for envelope in "$PENDING"/*.json; do
  [ -e "$envelope" ] || break
  [ "$processed" -lt "$MAX_PER_RUN" ] || break

  msg_id=$(jq -r '.message_id // ""' < "$envelope" 2>/dev/null)
  task=$(jq -r '.content // ""' < "$envelope" 2>/dev/null)
  if [ -z "$msg_id" ] || [ -z "$task" ]; then
    log "envelope $(basename "$envelope") malformed — moving to failed/"
    mv "$envelope" "$FAILED/"
    continue
  fi

  log "spawning codex model=$CODEX_MODEL for claude-outbox msg=$msg_id task='${task:0:80}…'"

  output_file=$(mktemp -t brain_spawn_claude_out_XXXXXX)
  if run_codex "$task" "$output_file"; then
    log "msg=$msg_id ok ($(wc -c < "$output_file") bytes output)"
    mv "$envelope" "$DONE/"
    SECRET=$(cat "$SECRET_FILE")
    curl -sS --max-time 5 -X POST \
      -H "Authorization: Bearer $SECRET" \
      -H 'Content-Type: application/json' \
      -d "$(jq -nc --arg id "$msg_id" --arg note "codex $CODEX_MODEL spawn ok" '{status:"done", note:$note, agent:"claude"}')" \
      "${BRAIN_URL}/brain/command/${msg_id}/ack" >/dev/null 2>&1 || true
  else
    rc=$?
    log "msg=$msg_id FAILED rc=$rc"
    mv "$envelope" "$FAILED/"
    SECRET=$(cat "$SECRET_FILE")
    curl -sS --max-time 5 -X POST \
      -H "Authorization: Bearer $SECRET" \
      -H 'Content-Type: application/json' \
      -d "$(jq -nc --arg id "$msg_id" --arg note "codex $CODEX_MODEL spawn failed rc=$rc" '{status:"rejected", note:$note, agent:"claude"}')" \
      "${BRAIN_URL}/brain/command/${msg_id}/ack" >/dev/null 2>&1 || true
  fi
  rm -f "$output_file"
  processed=$((processed + 1))
done

log "run complete: processed=$processed"
